# Airflow/Postgres defaults for local development
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow

# Comma-separated ticker symbols ingested each run
STOCK_SYMBOLS=AAPL,MSFT,NVDA

# Validation freshness threshold (hours)
MAX_DATA_AGE_HOURS=72

# Optional Airflow image override
AIRFLOW_IMAGE_NAME=apache/airflow:2.8.1-python3.10

